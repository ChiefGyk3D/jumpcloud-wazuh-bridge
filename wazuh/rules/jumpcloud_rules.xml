<!-- JumpCloud Bridge Rules (100300-100399) -->
<!-- Copy to /var/ossec/etc/rules/local_rules.xml on the Wazuh manager -->
<group name="jumpcloud,">

  <!-- Base rule: any JumpCloud event -->
  <rule id="100300" level="3">
    <decoded_as>json</decoded_as>
    <field name="jumpcloud_bridge.service" type="pcre2">.+</field>
    <description>JumpCloud: $(jumpcloud_bridge.event_type) on $(jumpcloud_bridge.service)</description>
    <group>jumpcloud,</group>
  </rule>

  <!-- Authentication success -->
  <rule id="100301" level="3">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.event_type" type="pcre2">admin_login_attempt|user_login_attempt|sso_auth</field>
    <field name="jumpcloud_bridge.success" type="pcre2">true|True</field>
    <description>JumpCloud: Successful authentication — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,authentication_success,</group>
  </rule>

  <!-- Authentication failure -->
  <rule id="100302" level="5">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.event_type" type="pcre2">admin_login_attempt|user_login_attempt|sso_auth</field>
    <field name="jumpcloud_bridge.success" type="pcre2">false|False</field>
    <description>JumpCloud: Failed authentication — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,authentication_failed,</group>
  </rule>

  <!-- Brute force: 5+ failed auth in short window -->
  <rule id="100303" level="10" frequency="5" timeframe="120">
    <if_matched_sid>100302</if_matched_sid>
    <description>JumpCloud: Possible brute-force — 5+ auth failures in 2 min</description>
    <group>jumpcloud,authentication_failed,brute_force,</group>
  </rule>

  <!-- User lifecycle: create/delete/lock/unlock -->
  <rule id="100310" level="5">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.event_type" type="pcre2">user_create|user_delete|user_lock|user_unlock|user_update</field>
    <description>JumpCloud: User lifecycle — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,user_lifecycle,</group>
  </rule>

  <!-- User deletion (high severity) -->
  <rule id="100311" level="8">
    <if_sid>100310</if_sid>
    <field name="jumpcloud_bridge.event_type">user_delete</field>
    <description>JumpCloud: User DELETED</description>
    <group>jumpcloud,user_lifecycle,</group>
  </rule>

  <!-- Admin changes -->
  <rule id="100320" level="8">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.event_type" type="pcre2">admin_create|admin_delete|admin_update|organization_update</field>
    <description>JumpCloud: Admin/org change — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,admin_change,policy_change,</group>
  </rule>

  <!-- Policy changes -->
  <rule id="100321" level="7">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.event_type" type="pcre2">policy_create|policy_update|policy_delete|group_create|group_update|group_delete</field>
    <description>JumpCloud: Policy/group change — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,policy_change,</group>
  </rule>

  <!-- MFA events -->
  <rule id="100330" level="5">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.event_type" type="pcre2">mfa_</field>
    <description>JumpCloud: MFA event — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,mfa,</group>
  </rule>

  <!-- RADIUS events -->
  <rule id="100340" level="3">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.service">radius</field>
    <description>JumpCloud: RADIUS event — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,radius,</group>
  </rule>

  <!-- LDAP events -->
  <rule id="100341" level="3">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.service">ldap</field>
    <description>JumpCloud: LDAP event — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,ldap,</group>
  </rule>

  <!-- LDAP bind auth failure -->
  <rule id="100342" level="5">
    <if_sid>100341</if_sid>
    <field name="jumpcloud_bridge.success" type="pcre2">false|False</field>
    <description>JumpCloud: LDAP bind auth failure</description>
    <group>jumpcloud,authentication_failed,ldap,</group>
  </rule>

  <!-- LDAP bind auth success -->
  <rule id="100343" level="3">
    <if_sid>100341</if_sid>
    <field name="jumpcloud_bridge.success" type="pcre2">true|True</field>
    <description>JumpCloud: LDAP bind auth success</description>
    <group>jumpcloud,authentication_success,ldap,</group>
  </rule>

  <!-- SSO events -->
  <rule id="100350" level="3">
    <if_sid>100300</if_sid>
    <field name="jumpcloud_bridge.service">sso</field>
    <description>JumpCloud: SSO event — $(jumpcloud_bridge.event_type)</description>
    <group>jumpcloud,sso,</group>
  </rule>

</group>
